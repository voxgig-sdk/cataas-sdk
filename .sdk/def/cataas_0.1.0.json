{
  "openapi": "3.0.3",
  "info": {
    "title": "CATAAS API",
    "description": "A REST API to spread peace and love (or not) thanks to cats. Provides various endpoints to get random cats, cats with specific tags, cat gifs, and more. Also allows customization of cat images and retrieving cat data in JSON format.",
    "version": "1.0.0",
    "contact": {
      "name": "CATAAS",
      "url": "https://cataas.com/"
    }
  },
  "servers": [
    {
      "url": "https://cataas.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/cat": {
      "get": {
        "summary": "Get a random cat",
        "description": "Returns a random cat image",
        "operationId": "getRandomCat",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "description": "Image type",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "xsmall",
                "small",
                "medium",
                "square"
              ]
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Image filter",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "blur",
                "mono",
                "negate",
                "custom"
              ]
            }
          },
          {
            "name": "brightness",
            "in": "query",
            "description": "Brightness level (used with filter=custom)",
            "required": false,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "lightness",
            "in": "query",
            "description": "Lightness level (used with filter=custom)",
            "required": false,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "saturation",
            "in": "query",
            "description": "Saturation level (used with filter=custom)",
            "required": false,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "hue",
            "in": "query",
            "description": "Hue level (used with filter=custom)",
            "required": false,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "r",
            "in": "query",
            "description": "Red channel (used with filter=custom)",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 255
            }
          },
          {
            "name": "g",
            "in": "query",
            "description": "Green channel (used with filter=custom)",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 255
            }
          },
          {
            "name": "b",
            "in": "query",
            "description": "Blue channel (used with filter=custom)",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 255
            }
          },
          {
            "name": "width",
            "in": "query",
            "description": "Custom width for the image",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "height",
            "in": "query",
            "description": "Custom height for the image",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "html",
            "in": "query",
            "description": "Return cat in HTML page (useful for Twitter or Facebook embedded render)",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "json",
            "in": "query",
            "description": "Return cat in JSON object",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "text/html": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cat/{tag}": {
      "get": {
        "summary": "Get a random cat with specific tag(s)",
        "description": "Returns a random cat image with the specified tag(s). Multiple tags can be combined with comma separator.",
        "operationId": "getRandomCatByTag",
        "parameters": [
          {
            "name": "tag",
            "in": "path",
            "description": "Tag(s) to filter cats. Multiple tags can be separated by comma.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "orange,cute"
          },
          {
            "name": "type",
            "in": "query",
            "description": "Image type",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "xsmall",
                "small",
                "medium",
                "square"
              ]
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Image filter",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "blur",
                "mono",
                "negate",
                "custom"
              ]
            }
          },
          {
            "name": "width",
            "in": "query",
            "description": "Custom width for the image",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "height",
            "in": "query",
            "description": "Custom height for the image",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "html",
            "in": "query",
            "description": "Return cat in HTML page",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "json",
            "in": "query",
            "description": "Return cat in JSON object",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "text/html": {
                "schema": {
                  "type": "string"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatResponse"
                }
              }
            }
          }
        }
      }
    },
